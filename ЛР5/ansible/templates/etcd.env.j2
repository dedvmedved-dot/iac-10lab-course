ETCD_NAME={{ etcd_name }}
ETCD_DATA_DIR=/var/lib/etcd/default
ETCD_LISTEN_PEER_URLS=http://{{ ansible_facts.default_ipv4.address }}:2380
ETCD_LISTEN_CLIENT_URLS=http://{{ ansible_facts.default_ipv4.address }}:2379,http://127.0.0.1:2379
ETCD_INITIAL_ADVERTISE_PEER_URLS=http://{{ ansible_facts.default_ipv4.address }}:2380
ETCD_ADVERTISE_CLIENT_URLS=http://{{ ansible_facts.default_ipv4.address }}:2379
ETCD_INITIAL_CLUSTER={% for host in groups['etcd'] %}{{ hostvars[host].etcd_name }}=http://{{ hostvars[host].ansible_facts.default_ipv4.address }}:2380{% if not loop.last %},{% endif %}{% endfor %}

ETCD_INITIAL_CLUSTER_TOKEN=lab5-e...
