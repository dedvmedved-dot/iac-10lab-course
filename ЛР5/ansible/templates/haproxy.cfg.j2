global
    log /dev/log local0
    maxconn 4096
    user haproxy
    group haproxy
    daemon

defaults
    log global
    mode tcp
    option tcplog
    timeout connect 10s
    timeout client 30s
    timeout server 30s

frontend pgsql
    bind *:5432
    default_backend pg_servers

backend pg_servers
    option httpchk GET /master
    {% for host in groups['postgres'] %}
    server {{ hostvars[host].patroni_name }} {{ hostvars[host].ansible_default_ipv4.address }}:5432 check port 8008
    {% endfor %}

listen stats
    bind *:8404
    mode http
    stats enable
    stats uri /
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_pass }}
