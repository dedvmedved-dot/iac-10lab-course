# terraform.tfvars для ЛР1
# cp terraform.tfvars.example terraform.tfvars
# Подставьте ВАШИ значения. НЕ коммитьте terraform.tfvars

# Proxmox API URL
proxmox_endpoint = "https://<ваш-ip>:8006/"

# Proxmox API-токен
proxmox_api_token = "<пользователь>!<токен-id>=<секрет>"

proxmox_node_name = "pve"

vm_id = 101

vm_name = "web-01"

vm_user = "ubuntu"

vm_ip = "192.168.0.101/24"

vm_gateway = "192.168.0.1"

ssh_public_key_path = "~/.ssh/id_ed25519.pub"
